---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('research')).sort(
  (a, b) => b.data.startDate.valueOf() - a.data.startDate.valueOf()
);

function formatRange(start: Date, end?: Date) {
  const fmt = (d: Date) =>
    d.toLocaleDateString('en-US', { month: 'short', year: 'numeric', timeZone: 'UTC' });
  return `${fmt(start)} – ${end ? fmt(end) : 'Present'}`;
}
---

<BaseLayout
  title="Research — Your Name"
  description="Labs, questions, and the research I've contributed to."
>
  <section class="mx-auto max-w-3xl px-6 py-20">
    <p class="mb-3 font-sans text-sm font-semibold uppercase tracking-wide text-terracotta-dark">
      Research
    </p>
    <h1 class="font-serif text-4xl font-semibold leading-tight text-ink sm:text-5xl">
      Research experience
    </h1>
    <p class="mt-4 max-w-xl text-lg leading-relaxed text-ink-soft">
      Placeholder intro — labs I've worked in, roughly newest first.
    </p>

    <div class="mt-12 divide-y divide-ink/10 border-t border-ink/10">
      {
        entries.map((entry) => (
          <div class="grid gap-2 py-8 sm:grid-cols-[9rem_1fr] sm:gap-8">
            <p class="text-sm tabular-nums text-ink-soft">
              {formatRange(entry.data.startDate, entry.data.endDate)}
            </p>
            <div>
              <h2 class="font-serif text-xl font-semibold text-ink">{entry.data.lab}</h2>
              <p class="mt-0.5 text-sm text-ink-soft">{entry.data.pi}</p>
              <p class="mt-3 max-w-xl text-base leading-relaxed text-ink-soft">
                {entry.data.description}
              </p>
              {entry.data.links && entry.data.links.length > 0 && (
                <div class="mt-3 flex flex-wrap gap-4 text-sm font-medium">
                  {entry.data.links.map((link) => (
                    <a
                      href={link.url}
                      class="text-terracotta-dark transition-colors hover:underline"
                    >
                      {link.label} &rarr;
                    </a>
                  ))}
                </div>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>
