---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('awards')).sort((a, b) => b.data.year - a.data.year);
---

<BaseLayout title="Awards — Aarith Veerabhadran" description="Honors, scholarships, and fellowships.">
  <section class="mx-auto max-w-3xl px-6 py-20">
    <p class="mb-3 font-sans text-sm font-semibold uppercase tracking-wide text-terracotta-dark">
      Awards
    </p>
    <h1 class="font-serif text-4xl font-semibold leading-tight text-ink sm:text-5xl">
      Awards &amp; honors
    </h1>
    <p class="mt-4 max-w-xl text-lg leading-relaxed text-ink-soft">
      Placeholder intro — honors and fellowships, newest first.
    </p>

    <div class="mt-12 divide-y divide-ink/10 border-t border-ink/10">
      {
        entries.map((entry) => (
          <div class="grid gap-2 py-8 sm:grid-cols-[9rem_1fr] sm:gap-8">
            <p class="text-sm tabular-nums text-ink-soft">{entry.data.year}</p>
            <div>
              <h2 class="font-serif text-xl font-semibold text-ink">{entry.data.name}</h2>
              <p class="mt-0.5 text-sm text-ink-soft">{entry.data.body}</p>
              <p class="mt-3 max-w-xl text-base leading-relaxed text-ink-soft">
                {entry.data.context}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>
