---
interface Photo {
  src: string;
  alt: string;
}

interface Props {
  photos: Photo[];
}

const { photos } = Astro.props;
---

<div class="columns-2 gap-4 sm:columns-3">
  {
    photos.map((photo, index) => (
      <button
        type="button"
        class="group mb-4 block w-full break-inside-avoid overflow-hidden rounded-xl border border-ink/10 focus:outline-none focus-visible:ring-2 focus-visible:ring-terracotta"
        data-lightbox-index={index}
        data-full-src={photo.src}
        data-alt={photo.alt}
      >
        <img
          src={photo.src}
          alt={photo.alt}
          loading="lazy"
          class="w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
        />
      </button>
    ))
  }
</div>
